<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pagination</title>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <style>
       /* Container & Layout */
.pagination-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid #e5e7eb;
  background-color: #ffffff;
  padding: 12px 16px;
  font-family: sans-serif;
}

/* Mobile Styling */
.pagination-mobile {
  display: flex;
  flex: 1;
  justify-content: space-between;
}

.btn-secondary {
  position: relative;
  display: inline-flex;
  align-items: center;
  border-radius: 6px;
  border: 1px solid #d1d5db;
  background-color: #ffffff;
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  text-decoration: none;
}

.btn-secondary:hover {
  background-color: #f9fafb;
}

/* Desktop Styling */
.pagination-desktop {
  display: none; /* Hidden on mobile */
}

.results-text {
  font-size: 14px;
  color: #374151;
}

.font-bold {
  font-weight: 600;
}

/* Nav Wrapper */
.pagination-nav {
  display: inline-flex;
  border-radius: 6px;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 0;
}

/* Shared Link Styles */
.nav-link, .nav-arrow {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 600;
  color: #111827;
  text-decoration: none;
  border: 1px solid #d1d5db;
  margin-left: -1px; /* Overlap borders */
}

.nav-link:hover, .nav-arrow:hover {
  background-color: #f9fafb;
}

/* Active State */
.nav-link.active {
  z-index: 10;
  background-color: #4f46e5;
  color: #ffffff;
  border-color: #4f46e5;
}

/* Arrows & Icons */
.nav-arrow {
  color: #9ca3af;
  padding: 8px 8px;
}

.nav-left { border-radius: 6px 0 0 6px; }
.nav-right { border-radius: 0 6px 6px 0; }

.icon {
  height: 20px;
  width: 20px;
}

.nav-dots {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8px 16px;
  font-size: 14px;
  color: #374151;
  border: 1px solid #d1d5db;
  margin-left: -1px;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

/* Responsive Breakpoint (640px) */
@media (min-width: 640px) {
  .pagination-mobile { display: none; }
  .pagination-desktop {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: space-between;
  }
}

/* Hide specific numbers on small tablets */
@media (max-width: 768px) {
  .hide-mobile { display: none; }
}
.table-container {
  overflow-x: auto;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  margin: 20px 0;
  font-family: sans-serif;
}

.custom-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  font-size: 14px;
}

.custom-table thead {
  background-color: #f9fafb;
  border-bottom: 1px solid #e5e7eb;
}

.custom-table th {
  padding: 12px 16px;
  font-weight: 600;
  color: #111827;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 12px;
}

.custom-table td {
  padding: 12px 16px;
  color: #4b5563;
  border-bottom: 1px solid #f3f4f6;
}

.custom-table tr:last-child td {
  border-bottom: none;
}

.custom-table tr:hover {
  background-color: #f3f4f6;
}

.font-bold {
  font-weight: 600;
  color: #111827;
}


    </style>
</head>
<body>
    <div class="table-container">
  <table class="custom-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Title</th>
        <th>Email</th>
        <th>Role</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="font-bold">John Doe</td>
        <td>Software Engineer</td>
        <td>john@example.com</td>
        <td>Admin</td>
      </tr>
      <tr>
        <td class="font-bold">Jane Smith</td>
        <td>Product Designer</td>
        <td>jane@example.com</td>
        <td>Member</td>
      </tr>
      <tr>
        <td class="font-bold">Whitney Francis</td>
        <td>Copywriter</td>
        <td>whitney@example.com</td>
        <td>Admin</td>
      </tr>
    </tbody>
  </table>
</div>

    <div class="pagination-container">
  <!-- Mobile View -->
  <div class="pagination-mobile">
    <a href="#" class="btn-secondary">Previous</a>
    <a href="#" class="btn-secondary">Next</a>
  </div>

  <!-- Desktop View -->
  <div class="pagination-desktop">
    <div>
      <p class="results-text">
        Showing <span class="font-bold">1</span> to <span class="font-bold">10</span> of <span class="font-bold">97</span> results
      </p>
    </div>
    <div>
      <nav class="pagination-nav" aria-label="Pagination">
        <a href="#" class="nav-arrow nav-left">
          <span class="sr-only">Previous</span>
          <svg viewBox="0 0 20 20" fill="currentColor" class="icon">
            <path d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
        </a>
        
        <a href="#" aria-current="page" class="nav-link active">1</a>
        <a href="#" class="nav-link">2</a>
        <a href="#" class="nav-link hide-mobile">3</a>
        <span class="nav-dots">...</span>
        <a href="#" class="nav-link hide-mobile">8</a>
        <a href="#" class="nav-link">9</a>
        <a href="#" class="nav-link">10</a>
        
        <a href="#" class="nav-arrow nav-right">
          <span class="sr-only">Next</span>
          <svg viewBox="0 0 20 20" fill="currentColor" class="icon">
            <path d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
        </a>
      </nav>
    </div>
  </div>
</div>


</body>
</html>