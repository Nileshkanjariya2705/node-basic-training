  <script>
    let gender = '';
    let relationship_status = '';
    let state = ''
    let city = ''

    const url = new URLSearchParams(window.location.search);
    const user_id = url.get('id');

    const language=new Array();
    const gujarati=new Array();
    const hindi=new Array();
    const english=new Array();

    async function get_user_date() {
      try {
        const res = await fetch(`http://localhost:8080/get/alldata/${user_id}`);
        const data = await res.json();
        console.log(data.language);

        document.getElementById('fname').value = data.basic_detail[0].first_name
        document.getElementById('lname').value = data.basic_detail[0].last_name
        document.getElementById('email').value = data.basic_detail[0].email
        document.getElementById('designation').value = data.basic_detail[0].designation
        document.getElementById('phoneNumber').value = data.basic_detail[0].last_name
        document.getElementById('dob').value = new Date(data.basic_detail[0].dob).toISOString().split('T')[0]
        document.getElementById('address1').value = data.address[0].address_1;
        document.getElementById('address2').value = data.address[0].address_2;
        document.getElementById('zip').value = data.address[0].zip_code;

        gender = data.basic_detail[0].gender;
        relationship_status = data.basic_detail[0].relationship_status;
        city = data.address[0].city;
        state = data.address[0].state;

        document.getElementById('rname').value = data.reference_detail[0].name
        document.getElementById('contect_number').value = data.reference_detail[0].contact_number
        document.getElementById('relation').value = data.reference_detail[0].relation


        document.getElementById('current_ctc').value = data.preferences[0].current_ctc
        document.getElementById('expected_ctc').value = data.preferences[0].expected_ctc
        document.getElementById('notice_period').value = data.preferences[0].notice_period


        let experience = document.getElementById('experience_table');
        for (let i = 0; i < data.work_experience.length; i++) {
          let row = document.createElement('tr');
          row.innerHTML = `
      
          <td>
            <label for="compnay_name">compnay_name:<input name="compnay_name[]" id="compnay_name" value=${data.work_experience[i].company_name} type="text"></label>
          </td>
            <td>
            <label for="work_designation">designation:<input name="work_designation[]" id="work_designation" value=${data.work_experience[i].designation} type="text"></label>
          </td>
           <td>
            <label for="start_date">start_date:<input name="start_date[]"  value=${new Date(data.work_experience[i].start_date).toISOString().split('T')[0]} id="start_date" type="date"></label>
          </td>
           <td>
            <label for="end_date">End date:<input name="end_date[]" id="end_date" value=${new Date(data.work_experience[i].end_date).toISOString().split('T')[0]}   type="date"></label>
          </td>
          <td>
            <input type="button" class="remove_eduction" value="-">
          </td>
       
           `

          experience.appendChild(row)
        }


        let eduction_table = document.getElementById('eduction_table');

        for (let j = 0; j < data.eduction_detail.length; j++) {
          let row = document.createElement("tr");

          row.innerHTML = `
     
                <td id="course_name">
                    <label for="course_name">course_name:<input id="course_name" value=${data.eduction_detail[j].course_name} name="course_name[]" type="text"></label>
                    
                </td>
                <td>
                    <label for="passing_year">passing year:<input id="passing_year" value=${data.eduction_detail[j].passing_year} name="passing_year[]" type="text"></label>
                    
                </td>
                <td>
                    <label for="uni_board">uni_board:<input id="uni_board" name="uni_board[]" value=${data.eduction_detail[j].uni_board} type="text"></label>
                    
                </td>
                <td>
                    <label for="result">result:<input id="result" name="result[]" value=${data.eduction_detail[j].result} type="text"></label>
                    
                </td>
                <td>
                    <input  type="button" class="remove_eduction" value="-">
                    
                </td>
            
    `
          eduction_table.appendChild(row);
        }


        data.language.forEach(lang=>{
            
            if(lang.language_name=='gujarati'){
              document.getElementById('gujarati').setAttribute('checked','')
              console.log(lang.can_read);
              
              if(lang.can_read){

                  console.log("can read true");
                  
                
                }
              if(lang.can_write){
                  console.log("can write true");
      
                
              }
              if(lang.can_speak){
                  console.log("can can_speak true");

              }
             
            }
             if(lang.language_name=='hindi'){
              document.getElementById('hindi').setAttribute('checked','')

              //  document.getElementById('hindi_speak').setAttribute('checked','')
              // document.getElementById('hindi_write').setAttribute('checked','')
              // document.getElementById('hindi_speak').setAttribute('checked','')

            } if(lang.language_name=='english'){
              document.getElementById('english').setAttribute('checked','')
              //  document.getElementById('eng_speak').setAttribute('checked','')
              // document.getElementById('eng_write').setAttribute('checked','')
              // document.getElementById('eng_speak').setAttribute('checked','')
          
            }
          
        })
        



      } catch (err) {
        console.log("errror", err.message);

      }
    }

    get_user_date();
    function display(value, id) {

      if (value.checked) {
        document.getElementById(`${id}`).style.display = 'block'
      } else {
        document.getElementById(`${id}`).style.display = 'none'

      }



    }

    function java_display(checked) {
      if (checked) {
        document.getElementById('java_container').style.display = 'block'
      } else {
        document.getElementById('java_container').style.display = 'none'

      }
    }
    function php_display(checked) {
      if (checked) {
        document.getElementById('php_container').style.display = 'block'
      } else {
        document.getElementById('php_container').style.display = 'none'

      }
    }
    function mysql_display(checked) {
      if (checked) {
        document.getElementById('mysql_container').style.display = 'block'
      } else {
        document.getElementById('mysql_container').style.display = 'none'

      }
    }
    function larava_display(checked) {
      if (checked) {
        document.getElementById('larava_container').style.display = 'block'
      } else {
        document.getElementById('larava_container').style.display = 'none'

      }
    }

    function remove_check(id) {
      if (id && id.wasChecked) {
        id.checked = false;
        id.wasChecked = false;
      } else {
        id.wasChecked = true;

      }

    }

    // dynamic combo box
    async function getdata(tech) {
      let container_top = document.getElementById(`${tech}`);
      let data = await fetch(`http://localhost:8080/get/select?name=${tech}`);
      let ans = await data.json();
      ans.forEach(lan => {
        let container = document.createElement("div")
        let input = document.createElement("input");
        input.setAttribute("id", lan.html_id)
        input.setAttribute("name", lan.unique_name)
        input.setAttribute("type", lan.html_type)
        input.setAttribute("value", lan.html_value)

        let label1 = document.createElement("label")
        label1.innerHTML = lan.html_name
        label1.appendChild(input)
        container.appendChild(label1);

        let option = getoption(lan.select_master_id, tech)
        option
          .then(data => {
            data.forEach(op => {

              let input = document.createElement("input");
              input.setAttribute("id", op.option_html_id)
              input.setAttribute("name", op.option_unique_name)
              input.setAttribute("type", op.option_html_type)
              input.setAttribute("value", op.option_html_value)
              let label = document.createElement("label")
              label.innerHTML = op.option_html_name
              label.appendChild(input)
              container.appendChild(label)
            })


          })
          .catch("data not found")
        let p = document.createElement("p");
        p.setAttribute("id", "e_" + lan.html_id);
        container_top.appendChild(container)
        container_top.appendChild(p)


      })
    }

    async function getoption(id, tech) {
      let data = await fetch(`http://localhost:8080/get/option/${id}`)
      let ans = await data.json();
      return ans;
    }
    getdata("language[]")
    getdata("tech[]")

    async function getselect(val) {
      let city = document.getElementById(`${val}`);
      let data = await fetch(`http://localhost:8080/get/select?name=${val}`);
      let ans = await data.json();

      // console.log(ans[0]);



      let select = document.createElement("select");
      select.setAttribute("id", ans[0].html_id)
      select.setAttribute("name", ans[0].unique_name)

      if (val == 'preferred') {
        select.setAttribute('multiple', '')
      }

      let option = getoption(ans[0].select_master_id, val);



      option
        .then(d => {
          d.forEach(op => {
            let options = document.createElement("option");
            options.setAttribute("value", op.option_html_value)
            options.innerText = op.option_html_name

            if (op.option_html_value === gender) {
              options.setAttribute('selected', '')
            } else

              if (op.option_html_value === relationship_status) {
                options.setAttribute('selected', '')
              } else

                if (op.option_html_value === state) {
                  options.setAttribute('selected', '')
                } else

                  if (op.option_html_value == city) {
                    options.setAttribute('selected', '')
                  }
            select.appendChild(options);
          })
        }).catch(() => {
          console.log("data not found");
        })

      city.appendChild(select)
    }
    getselect("state")
    getselect("department")
    getselect("relationship_status")
    getselect("city")
    getselect("gender")
