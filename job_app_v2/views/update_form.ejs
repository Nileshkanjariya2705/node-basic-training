<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>job_application_form</title>
  <style>
    /* body {
      background-color: antiquewhite;
    } */

    fieldset {
      margin-top: 30px;
      width: 80vw;
    }


    .references_contect,
    .preferences {
      display: grid;

      grid-template-columns: 1fr 1fr 1fr;

      grid-template-areas: "left middel right";

    }

    .Eduction,
    .work_experience,
    .language_known {
      display: grid;

      grid-template-columns: 1fr 1fr 1fr 1fr;

      grid-template-areas: "1 2 3 4";


    }

    .container {
      display: grid;
      grid-template-areas: "left left" "right right";
      width: 100%;

      gap: 30px;
    }

    table,
    td,
    tr,
    th {
      border: 1px solid black;
      border-collapse: collapse;
    }

    table {
      width: 90vw;
    }

    td {
      height: 50px;
    }

    label {
      margin-left: 10px;

    }


    .table_container,
    .eduction_container {
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .table_container th {
      width: 200px;
      border: 1px solid black;

    }

    .eduction_container th {
      width: 200px;
      border: 1px solid black;
    }


    .form-group {
      margin-top: 8px;
    }

    input::placeholder {
      color: red;
    }

    p {
      color: red;
    }

    .container {
      /* display: flex; */
      /* align-items: center;
            justify-content: center; */
    }

    table,
    th {
      /* text-align: center;
            border-collapse: collapse; */

    }

    tr:hover {
      background-color: rgb(169, 183, 234);
      color: white;
    }

    /* th,td{
            border-bottom: 1px solid black;
            height: 30px
        } */
    table {
      width: 100%;
    }

    .sidenav {
      height: 100%;
      width: 200px;
      background-color: rgb(169, 183, 234);
      position: fixed;
      top: 0;
      left: 0;
      text-align: center;
      padding-top: 100px;


    }

    .main {
      margin-left: 220px;
      /* border: 1px solid black; */
      height: 100%;

    }

    a {
      text-decoration: none;
      margin-top: 20px;
    }

    .btn {
      margin-bottom: 20px;
      border: 1px solid white;
      background-color: white;
      border-radius: 10px;
      cursor: pointer;
    }

    .footer {
      position: fixed;
      width: 100%;
      bottom: 100px;
      /* margin-left: auto;
          margin-right: auto;
          position: fixed; */
    }
  </style>
</head>

