<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>view user detail</title>
    <style>
        .container{
            display: flex;
            align-items: center;
            justify-content: center;
        }
        table,th{
           text-align: center;
            border-collapse: collapse;
           
        }
        tr:hover{
             background-color: rgb(169, 183, 234);
            color: white;
        }
        th,td{
            border-bottom: 1px solid black;
            height: 30px
        }
        table{
            width: 100%;
        }
       
        .sidenav{
            height: 100%;
            width: 200px;
            background-color: rgb(169, 183, 234);
            position: fixed;
            top: 0;
            left: 0;
            text-align: center;
            padding-top: 100px;
           

        }
        .main{
            margin-left: 220px;
            
        }
        a{
            text-decoration: none;
         
            margin-top: 20px;
        }
        .btn{
            margin-bottom: 20px;
            border: 1px solid white;
            background-color: white;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <%- include('/home/nilesh-kanjariya/node js/job_app_v2/views/partials/head.ejs') %>
   
    <div class="main">
          <h1 style="text-align: center;">Experince Data</h1>
    <div class="container">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>BASIC_DETAIL ID</th>
                    <th>COMPANY NAME</th>
                    <th>DESINGATION</th>
                    <th>START DATE</th>
                    <th>END DATE</th>
                  
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="body">
                
            </tbody>
        </table>
    </div>
    </div>
    <script>
         async function getdata() {
        try{
            const response=await fetch("http://localhost:8080/get/experience")
            const data=await response.json();
            let tbody=document.getElementById("body");

            data.forEach(ex=>{
                let tr=document.createElement("tr");
                tr.innerHTML=`
                     <td>${ex.work_experience_id}</td>
                     <td>${ex.basic_detail_id}</td>
                     <td>${ex.company_name}</td>
                     <td>${ex.designation}</td>
                     <td>${new Date(ex.start_date).toLocaleDateString()}</td>
                     <td>${new Date(ex.end_date).toLocaleDateString()}</td>
                   
                        
                        <td>
                        <input type="button" onclick='window.location.href="/edit_work_experience?id=${ex.work_experience_id}"' value="edit">
                        <input type="button" onclick="remove(${ex.work_experience_id})" value="delete">
                            </td>
                       
                `
                tbody.appendChild(tr);
            })
        }catch(err){
            console.error(err.message);
            
        }
    }

    getdata()

    // delte function
     async function remove(id){
    let msg=document.getElementById('msg');
       try{
            const res=await fetch(`http://localhost:8080/delete/experience?id=${id}`)
            if (!res.ok) {
            throw new Error(`HTTP error! Status: ${res.status}`);
            }
            const data=await res.json();
            
            console.log(data.msg);
            window.location.reload();
            
            
       }catch(err){
        console.error("somthing went wrong");
        if (!msg) {
            msg.innerHTML = 'Something went wrong, data not deleted';
        }
       } 
    }
    </script>
  
</body>
</html>