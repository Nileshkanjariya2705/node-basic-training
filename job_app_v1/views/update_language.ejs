<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>update language</title>

</head>
<body> 
        <h1 style="text-align: center;" >edite language</h1>
    <fieldset style="text-align: center;" id="language_known">
      <legend>Language Known</legend>
        <form action="/language/update/<%=data.language_known_id%>" onsubmit="return error()" method="post">
      <!-- Row 1: Gujarati -->
      <div class="form-group">
        <label><input  type="checkbox" name="language_name"  value="<%=data.language_name%>"  checked  > <%=data.language_name%></label>
          <div style="margin-top: 10px;" id="gujarati_container" >
            <label><input type="checkbox" name="can_read" <%= data.can_read=='1'?'checked':'' %>   > Read</label>
        <label><input type="checkbox" name="can_write" <%= data.can_write=='1'?'checked':'' %>   > Write</label>
        <label><input type="checkbox" name="can_speak" <%= data.can_speak=='1'?'checked':'' %>   > Speak</label>
          </div>

        <p style="color: red;" id="e_skill" class="error-msg"></p>
      </div>
      <div class="form-group">
        <input type="submit" value="Update">
      </div>
</form>
      <!-- Row 2: Hindi -->
