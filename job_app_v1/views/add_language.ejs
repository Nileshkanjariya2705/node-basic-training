<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add language</title>

</head>
<body> 
        <h1 style="text-align: center;" >edite language</h1>
    <fieldset style="text-align: center;" id="language_known">
      <legend>Language Known</legend>
        <form action="/language/add/<%=id%>" onsubmit="return error()" method="post">
      <!-- Row 1: Gujarati -->
      <div class="form-group">
        <label id="language_name" >language_name: </label>
        <input  name="language_name" id="language_name" type="text" >
                <p style="color: red;" id="e_language_name" class="error-msg"></p>

          <div style="margin-top: 10px;" id="gujarati_container" >
            <label><input type="checkbox" name="can_read"   > Read</label>
        <label><input type="checkbox" name="can_write"    > Write</label>
        <label><input type="checkbox" name="can_speak"   > Speak</label>
          </div>

        <p style="color: red;" id="e_skill" class="error-msg"></p>
      </div>
      <div class="form-group">
        <input type="submit" value="ADD">
      </div>
</form>
      <!-- Row 2: Hindi -->
      <!-- <div class="form-group">
        <label><input onclick="document.getElementById('hindi_container').style.display='block'" type="checkbox" name="language[]" value="hindi"> Hindi</label>
        <div id="hindi_container" style="display: none; margin-top: 10px;">
