    </fieldset>
    <script>
        function error(){
            let invalid=true;
            document.getElementById('e_language_name').innerHTML=''
            document.getElementById('e_skill').innerHTML=''


         
        let language_name=document.getElementsByName('language_name')[0].value.trim();    
        let can_read=document.getElementsByName('can_read')[0].checked;
        let can_write=document.getElementsByName('can_write')[0].checked;
        let can_speak=document.getElementsByName('can_speak')[0].checked;
         
        if(language_name===''){
            document.getElementById('e_language_name').innerHTML='language name is require'
            invalid=false;

        }
        if(!can_read && !can_speak && !can_write){
            document.getElementById('e_skill').innerHTML='please select at least on language level'
            invalid= false
        }
        return invalid;

    }

    </script>
</body>
